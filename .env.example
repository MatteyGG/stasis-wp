DATABASE_URL="url-to-database"
TELEGRAM_BOT_TOKEN=telegram-bot-token
TELEGRAM_CHAT_ID=telegram-chat-id

AUTH_SECRET="auth-secret"
AUTH_TRUST_HOST=true
NEXT_PUBLIC_BASE_URL=url
NEXTAUTH_URL=same-as-base-url

AWS_S3_REGION=REGION
AWS_S3_ACCESS_KEY_ID=ACCESS_KEY
AWS_S3_SECRET_ACCESS_KEY=SECRET_KEY
AWS_S3_BUCKET_NAME=BUCKET_NAME
AWS_S3_ENDPOINT=ENDPOINT

# Matrix auto-provision on site registration (optional)
MATRIX_REGISTRATION_ENABLED=false
MATRIX_HOMESERVER_URL=https://matrix.stasis-wp.ru
MATRIX_SERVER_NAME=matrix.stasis-wp.ru
MATRIX_ADMIN_ACCESS_TOKEN=put_synapse_admin_access_token_here
MATRIX_USER_PREFIX=wp
# Registration flow note:
# - site registration does NOT auto-create Matrix user
# - Matrix link/reset is done from profile modal via /api/user/matrix
